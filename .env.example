# Resend email integration for the calculator quiz.
# Set these in Vercel: Project → Settings → Environment Variables.
# Server-side only — do NOT prefix with VITE_.

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where internal lead alerts go. Comma-separated, no spaces required.
INTERNAL_EMAILS=gary@stellarvoiceagents.com,david@mindsheep.com.au

# The verified sender on Resend. Format: "Display Name <addr@domain>".
# Domain must be verified in Resend (DNS records on stellarvoiceagents.com).
FROM_EMAIL=Stellar Voice Agents <hello@stellarvoiceagents.com>

# Optional. Where Reply-To points for the client confirmation email.
# Defaults to the first INTERNAL_EMAILS entry if omitted.
REPLY_TO_EMAIL=gary@stellarvoiceagents.com
